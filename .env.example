# Agent Framework v2.0 — Environment Variables

# LLM Providers (set at least one)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
OPENROUTER_API_KEY=sk-or-...
OLLAMA_HOST=http://localhost:11434
OLLAMA_ENABLED=false

# Transport Tokens (set for your platform)
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=
DISCORD_APP_ID=

# iMessage (macOS only — requires Full Disk Access for Terminal/Node)
# The agent NEVER auto-responds: every reply requires the trigger phrase below.
# Your phone number (+15551234567) or Apple ID email — used to detect the
# self-thread (note-to-self) so messages you send yourself can invoke the agent.
IMESSAGE_SELF_ID=9568562376
# Trigger phrase that activates the agent in any thread (case-insensitive).
IMESSAGE_TRIGGER=hey agent
# Number of recent thread messages pulled as context for each invocation.
IMESSAGE_CONTEXT_MESSAGES=10
# Delay in ms before the agent replies, so it feels less robotic.
IMESSAGE_RESPONSE_DELAY_MS=1500

# Framework Settings
DATA_DIR=./data
LOG_LEVEL=info
LOG_FILE=
COST_PREFERENCE=standard
LATENCY_PREFERENCE=fast
REFLECTION_ENABLED=true
