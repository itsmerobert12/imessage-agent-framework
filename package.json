{
  "name": "agent-framework",
  "version": "2.0.0",
  "description": "Self-improving multi-agent framework with dynamic agent spawning, multi-LLM orchestration, and multi-platform transport",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/main.ts",
    "dev:cli": "ts-node src/main.ts --transport=cli",
    "dev:telegram": "ts-node src/main.ts --transport=telegram",
    "dev:discord": "ts-node src/main.ts --transport=discord",
    "dev:imessage": "ts-node src/main.ts --transport=imessage",
    "start": "node dist/main.js",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "better-sqlite3": "^11.7.0",
    "discord.js": "^14.16.0",
    "dotenv": "^16.4.7",
    "grammy": "^1.35.0",
    "node-fetch": "^3.3.2",
    "ollama": "^0.5.14",
    "openai": "^4.77.0",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.0",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
