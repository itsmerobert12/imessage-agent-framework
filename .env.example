# Agent Framework v2.0 — Environment Variables

# ── LLM Providers ─────────────────────────────────────────────────
# Configure at least one provider. Cloud providers are tried first per
# the model selected by the orchestrator. If a cloud call fails (rate
# limit, quota exhausted, network error, missing key), the framework
# automatically falls back to a local Ollama model picked by task
# domain (coding → qwen2.5-coder:7b, otherwise → mistral:7b, etc.).
# If no cloud keys are configured at all, the orchestrator only picks
# Ollama models from the start. This keeps long-running transports
# (e.g. iMessage) up even when cloud APIs are degraded.
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
OPENROUTER_API_KEY=sk-or-...

# ── Local Ollama (fallback safety net) ────────────────────────────
# Ollama is enabled by default for fallback. Set OLLAMA_ENABLED=false
# to opt out entirely. On startup the framework pings OLLAMA_HOST and
# logs which local models are pulled. Recommended: pull at least
# `mistral:7b` and `qwen2.5-coder:7b` so fallback has something to use.
#   ollama pull mistral:7b
#   ollama pull qwen2.5-coder:7b
OLLAMA_HOST=http://localhost:11434
OLLAMA_ENABLED=true

# ── Transport Tokens ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=
DISCORD_APP_ID=

# ── Framework Settings ────────────────────────────────────────────
DATA_DIR=./data
LOG_LEVEL=info
LOG_FILE=
COST_PREFERENCE=standard
LATENCY_PREFERENCE=fast
REFLECTION_ENABLED=true
